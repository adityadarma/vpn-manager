# ============================================================
# VPN Manager — Agent Configuration (Standalone Deployment)
# ============================================================
# Use this file when deploying agent on a VPN node server
# Copy to /opt/vpn-agent/.env on the VPN server
# ============================================================

# Node Environment
NODE_ENV=production

# Manager API Connection
AGENT_MANAGER_URL=http://localhost:3000
AGENT_NODE_ID=change-me
AGENT_SECRET_TOKEN=change-me

# VPN Token (for authentication)
VPN_TOKEN=change-me

# Polling & Heartbeat Intervals (milliseconds)
AGENT_POLL_INTERVAL_MS=5000
AGENT_HEARTBEAT_INTERVAL_MS=30000

# VPN Type Selection (openvpn | wireguard)
VPN_TYPE=openvpn
